blink_modules_sources("isthari") {
  sources = [
    "dom_window_decklink.cc",
    "dom_window_decklink.h",
    "linked_list.cc",
    "linked_list.h",
    "video_card.cc",
    "video_card.h",
    "video_card_mode.cc",
    "video_card_mode.h",
    "base/callback_helper.cc",
    "base/callback_helper.h",
    "sdi/decklink/decklink_input_stream.cc",
    "sdi/decklink/decklink_input_stream.h",
    "sdi/decklink/decklink_output_stream.cc",
    "sdi/decklink/decklink_output_stream.h",    
    "ndi/ndi_input_stream.cc",
    "ndi/ndi_input_stream.h",
    "ndi/ndi_manager.cc",
    "ndi/ndi_manager.h",
    "ndi/ndi_output_stream.cc",
    "ndi/ndi_output_stream.h",
  ]
  deps = [
    "//media",
    "//media/mojo:buildflags",
#    "//media/mojo/clients",
    "//media/mojo/mojom",
    "//third_party/libaom:libaom_buildflags",
    "//third_party/libyuv:libyuv",
    "//third_party/opus",
    "//third_party/decklink",
  ]

if (is_win) {
  libs = [
    "Processing.NDI.Lib.x64.lib"
  ]
}
if (is_linux){
  libs = [
    "ndi"
  ]
}
  public_deps = [ "//third_party/blink/renderer/modules/webaudio:webaudio" ]
}

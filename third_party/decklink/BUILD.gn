if (is_mac) {
  static_library("decklink") {
    sources = [ "mac/include/DeckLinkAPIDispatch.cpp" ]
    frameworks = [
      "CoreFoundation.framework",
      "IOKit.framework",
    ]
  }
}

if (is_linux) {
  static_library("decklink") {
    sources = [
      "linux/platform.cpp", 
      "linux/DeckLinkAPIDispatch.cpp" 
    ]
  }
}

if (is_win) {
  static_library("decklink") {
    sources = [
      "win/platform.cpp",
      "win/DeckLinkAPI_i.c" 
    ]
  }
}
